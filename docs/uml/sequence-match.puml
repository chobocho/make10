@startuml sequence-match
title Match Flow — Drag → Sum=10 (wildcard-aware) → Score (chain × bonus) → Effects → Stuck Rescue
skinparam responseMessageBelowArrow true
actor User
participant "PointerInput" as PI
participant "GameApp\n(loop)" as App
participant "FSM" as FSM
participant "GameScene" as GS
participant "Selector" as Sel
participant "Board" as Board
participant "Hint" as Hint
participant "EffectLayer" as Fx
participant "AudioManager" as Audio

User -> PI : touchstart / mousedown
PI -> App : onDown(x, y)
App -> FSM : onPointerDown(x, y)
FSM -> GS : onPointerDown(x, y)
GS -> Sel : begin(col, row)
GS -> Audio : play("select")

User -> PI : drag (move)
PI -> App : onMove(x, y)
App -> FSM : onPointerMove(x, y)
FSM -> GS : onPointerMove(x, y)
GS -> Sel : extend(col, row)
note right of Sel
  4-adjacent only, length <= 3
  isWildSum10 allows
  (W,X) / (W,W) / (W,X,Y)
end note

User -> PI : touchend / mouseup
PI -> App : onUp(x, y)
App -> FSM : onPointerUp(x, y)
FSM -> GS : onPointerUp(x, y)
GS -> Sel : commit() : { positions, sum, valid }

alt valid match
  GS -> Board : isBonus(c,r) for each pos\n=> hitBonus
  GS -> Board : applyMatch(positions)
  note right of Board
    on destroy: also clears wild/bonus flags
    multilife: both lives>=2 -> min damage
  end note

  GS -> GS : chainCount = (Δt <= 1s) ? prev+1 : 1\nchainBonus = min(250, 50 * (chain - 1))
  GS -> GS : base = 100 (pair) / 300 (triple)\ntotal = (base + chainBonus) * (hitBonus ? 2 : 1)

  GS -> Fx : spawnRemoval(destroyed, layout, kind,\n  { chainBonus?, scoreOverride?, multiplier? })
  note right of Fx
    particles + score popup + (triple) ring
    multiplier > 1 -> rainbow palette + x2 badge
    chainBonus > 0 -> "+50 x2" lightning badge
  end note

  GS -> Board : applyGravity()  // wild/bonus preserved, falls through obstacles
  GS -> Board : refill(rng)
  GS -> GS : syncBonusCellAfterMutation()
  GS -> Hint : clear()
  GS -> GS : score += total
  GS -> Audio : play("remove")

  GS -> Board : findValidCombination()  // wildcard-aware
  alt no valid combo and wildEnabled
    GS -> Board : convertToWildcard(c, r)  // pick a non-obstacle, non-wild cell
    GS -> Fx : spawnWildcardEntrance(c, r, layout)
    GS -> Audio : play("wild")
    GS -> Board : findValidCombination() (recheck)
    alt still no combo
      GS -> GS : endGame("stuck")
      GS -> FSM : transition("result", result)
    end
  else combo exists
  end

else invalid (>=2 cells, sum != 10)
  GS -> Audio : play("invalid")
end

== Background timers (update loop) ==
App -> GS : update(deltaMs)
GS -> GS : elapsedMs += deltaMs (active time only)

alt nextWildSpawnMs <= 0 (12-25s interval)
  GS -> Board : convertToWildcard(random cell)
  GS -> Fx : spawnWildcardEntrance / Audio: "wild"
  GS -> GS : nextWildSpawnMs = pickNextWildInterval()
end

alt !bonusCell and nextBonusSpawnMs <= 0 (10-12s interval)
  GS -> Board : markBonus(random cell)
  GS -> GS : bonusCell = { col, row, expireAtMs = elapsedMs + rand(2-5s) }
  GS -> Fx : spawnBonusEntrance / Audio: "bonus"
end

alt bonusCell and elapsedMs >= expireAtMs
  GS -> Board : unmarkBonus(c, r)  // x2 window expired; cell becomes a normal cell
  GS -> GS : bonusCell = null
end
@enduml
