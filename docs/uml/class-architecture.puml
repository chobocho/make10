@startuml class-architecture
title Make10 — Class Architecture
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members
top to bottom direction

package "core" {
  class GameApp {
    +start()
    +stop()
    -tryResumeSession()
    -loop()
  }
  class FSM {
    +register(id, scene)
    +transition(id, args)
    +update(dt)
    +render()
  }
  GameApp *-- FSM
}

package "scenes" {
  interface Scene
  class TitleScene {
    -page: number
    +isPageUnlocked(n): boolean
    +isMapUnlocked(id): boolean
  }
  class GameScene {
    -score: number
    -elapsedMs: number
    -chainCount: number
    -bonusCell: { col, row, expireAtMs } | null
    -nextWildSpawnMs / nextBonusSpawnMs
    +pauseGame() / resumeGame() / restartMap()
  }
  class ResultScene
  class TutorialOverlay {
    -phase: number
    +start() / update(dt) / onPointerUp(x,y)
  }
  Scene <|.. TitleScene
  Scene <|.. GameScene
  Scene <|.. ResultScene
  GameScene *-- TutorialOverlay
}
FSM o-- Scene

package "game logic (pure)" {
  class Board {
    -grid: number[][]
    -lives: number[][]
    -obstacles: boolean[][]
    -wildcards: boolean[][]
    -bonus: boolean[][]
    +applyMatch(positions): number
    +applyGravity()  // wild/bonus preserved, falls through obstacles
    +refill(rng)
    +convertToWildcard(c,r) / markBonus(c,r) / unmarkBonus
    +isObstacle / isWildcard / isBonus
    +snapshot / livesSnapshot / obstaclesSnapshot
    +wildcardsSnapshot / bonusSnapshot
  }
  class Selector {
    +begin(c,r) / extend(c,r)
    +commit(): SelectionResult
    +isValidForRemoval()  // wildcard-aware
  }
  class Timer {
    +start() / pause() / resume()
    +tick(dt) / setElapsedMs(ms)
  }
  class Hint {
    +request() / tick(dt)
  }
  Selector --> Board
  Hint --> Board
  note bottom of Selector
    isWildSum10:
      W = wildcard count, S = sum of fixed cells
      match valid iff (10 - S) ∈ [W, 9·W]
  end note
}

package "renderer" {
  class CanvasRenderer
  class BoardRenderer {
    +setLayout(l)
    +draw(board, options)
    ' phaseMs option drives bonus rainbow animation
  }
  class UIRenderer {
    +drawHUD(layout, state)
  }
  class EffectLayer {
    +spawnRemoval(cells, layout, kind, opts?)
    +spawnWildcardEntrance(c, r, layout)
    +spawnBonusEntrance(c, r, layout)
    +update(dt) / render(ctx) / clear()
  }
  BoardRenderer --> CanvasRenderer
  UIRenderer --> CanvasRenderer
}

package "io" {
  class PointerInput
  class AudioManager
  note bottom of AudioManager
    sounds:
    select / remove / hint / invalid
    clear / gameover / button
    wild / bonus
  end note
}

package "data" {
  class MapData <<value>> {
    +id, name, cols, rows
    +timeLimit, hintCount
    +starThresholds[3]
    +initialBoard, initialLives?
    +initialObstacles?  // introduced at id >= 101
    +initialWildcards?  // dynamic spawn target; static maps unused
  }
  class MapLoader {
    +loadMap(id) / validateMap(input)
    +mapJsonUrl(id)
  }
}

package "storage (IndexedDB v3)" {
  class SaveManager {
    +saveBest / load / list
    +saveSession / loadSession / clearSession
    +markTutorialDone / isTutorialDone
    +addHintCarryover / consumeHintCarryover / peekHintCarryover
  }
  interface ProgressStore
  interface MetaStore
  class ProgressRecord <<value>> {
    +mapId, score, stars
    +boardState, boardLives?
    +boardObstacles?
    +boardWildcards?
    +boardBonus?
    +timeLeft, hintsLeft?
    +timestamp
  }
  SaveManager --> ProgressStore
  SaveManager --> MetaStore
  ProgressStore ..> ProgressRecord
  note bottom of MetaStore
    keys:
    tutorial_done (bool)
    hint_carryover (int)
  end note
}

' GameApp wires the top-level dependencies
GameApp *-- CanvasRenderer
GameApp *-- AudioManager
GameApp *-- SaveManager
GameApp *-- PointerInput

' GameScene composes game logic + renderers
GameScene *-- Board
GameScene *-- Selector
GameScene *-- Timer
GameScene *-- Hint
GameScene *-- BoardRenderer
GameScene *-- UIRenderer
GameScene *-- EffectLayer
GameScene ..> SaveManager : sessions / meta / hint carryover
GameScene ..> AudioManager
GameScene ..> MapData

TutorialOverlay *-- BoardRenderer
TutorialOverlay ..> Board : owns mini-board

TitleScene ..> SaveManager : list best stars
ResultScene ..> SaveManager : saveBest + addHintCarryover (★3)
@enduml
