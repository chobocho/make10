@startuml sequence-progression
title Level Progression — Sequential Lock + Page Gating + Three-Star Hint Carryover
skinparam responseMessageBelowArrow true
actor User
participant "TitleScene" as Title
participant "GameScene" as GS
participant "ResultScene" as RS
participant "SaveManager" as SM
participant "IndexedDB\n(progress + meta)" as IDB

== Title enter — display pages and lock state ==
User -> Title : enter
Title -> SM : list() (all progress records)
SM -> IDB : transaction(readonly)
IDB --> SM : [{ mapId, stars }, ...]
SM --> Title : records
Title -> Title : page = 1 (shows 1-100)
note right of Title
  Page lock:
    page 2 unlocked iff bestStars[100] >= 1
    page 3 unlocked iff bestStars[200] >= 1
  Map lock:
    map N unlocked iff bestStars[N-1] >= 1
    (map 1 always unlocked)
end note

== Page navigation via arrow ==
User -> Title : tap right arrow
alt unlocked
  Title -> Title : page++ , scrollY = 0
else locked
  note right of Title : ignore (no sound)
end

== Map card tap ==
User -> Title : tap map N
alt isMapUnlocked(N)
  Title -> GS : transition("game", { map })
else locked
  note right of Title : padlock shown, ignored
end

== GameScene enter (fresh) — apply hint carryover ==
GS -> SM : consumeHintCarryover()
SM -> IDB : meta["hint_carryover"] -> reset to 0
SM --> GS : extraHints (e.g., 1)
GS -> GS : hints = map.hintCount + extraHints
note right of GS
  if mapId % 8 == 0:
    hints = max(hints, 3) "fill every 8 levels"
end note
GS -> GS : new Hint(board, hints)

== Game ends -> ResultScene ==
GS -> RS : transition("result", { score, stars, mapId, ... })
alt cleared (stars >= 1)
  RS -> SM : saveBest(record)
  SM -> IDB : progress.put(mapId, ...)
  alt stars == 3
    RS -> SM : addHintCarryover()
    SM -> IDB : meta["hint_carryover"] += 1
    note right of RS : +1 auto-applied at next entry
  end
end

== Next / Retry ==
User -> RS : tap "Next"
alt hasNext (cleared and N < maxMapId)
  RS -> GS : transition("game", { map: N+1 })
  GS -> SM : consumeHintCarryover() (loop above)
else disabled
  note right of RS : failed run or last map -> ignored
end

User -> RS : tap "Title"
RS -> Title : transition("title")
Title -> SM : list() (reload — reflects new stars / unlocks)
@enduml
